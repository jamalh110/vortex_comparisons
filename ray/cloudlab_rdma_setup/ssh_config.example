  User jamalh11
  IdentityFile ~/.ssh/id_ed25519

Host node3
  HostName node3.example.wisc.cloudlab.us
  User jamalh11
  IdentityFile ~/.ssh/id_ed25519

Host node4
  HostName node4.example.wisc.cloudlab.us
