# Source this file from the CloudLab login node (node0).
# Change these values when a new reservation uses different names or addresses.

export CLOUDLAB_USER="${CLOUDLAB_USER:-jamalh11}"
export USER_HOME="${USER_HOME:-/users/${CLOUDLAB_USER}}"
export REPO_ROOT="${REPO_ROOT:-${USER_HOME}/vortex_comparisons}"
export RAY_ROOT="${RAY_ROOT:-${REPO_ROOT}/ray}"
export SETUP_ROOT="${SETUP_ROOT:-${RAY_ROOT}/cloudlab_rdma_setup}"
export PIPELINE_ROOT="${PIPELINE_ROOT:-${RAY_ROOT}/pipeline1}"
export DATA_ROOT="${DATA_ROOT:-/mydata}"
export HF_HOME="${HF_HOME:-${DATA_ROOT}/hf_home}"
export HF_DATASETS_CACHE="${HF_DATASETS_CACHE:-${DATA_ROOT}/datasets_cache}"
export WORK_ROOT="${WORK_ROOT:-${USER_HOME}/workspace}"
export LOG_ROOT="${LOG_ROOT:-${USER_HOME}/raylogs}"

export LOCUST_NODE="${LOCUST_NODE:-node0}"
export HEAD_NODE="${HEAD_NODE:-node1}"
export STEP_B_NODES="${STEP_B_NODES:-node1 node2 node3}"
export RAY_NODES="${RAY_NODES:-node1 node2 node3 node4}"
export ALL_NODES="${ALL_NODES:-node0 node1 node2 node3 node4}"
export MIG_NODE="${MIG_NODE:-node4}"

export LOCUST_IP="${LOCUST_IP:-10.10.1.1}"
export HEAD_IP="${HEAD_IP:-10.10.1.2}"
export NODE2_IP="${NODE2_IP:-10.10.1.3}"
export NODE3_IP="${NODE3_IP:-10.10.1.4}"
export MIG_IP="${MIG_IP:-10.10.1.5}"

export RDMA_DEVICE="${RDMA_DEVICE:-mlx5_0}"
export RDMA_PORT="${RDMA_PORT:-1}"
export RDMA_NETDEV="${RDMA_NETDEV:-enp65s0np0}"
export ROCE_GID_INDEX="${ROCE_GID_INDEX:-3}"

export RAY_VERSION="${RAY_VERSION:-2.56.0}"
export NIXL_VERSION="${NIXL_VERSION:-1.3.1}"
export OFED_VERSION="${OFED_VERSION:-23.10-3.2.2.0}"
export CUDA_VERSION="${CUDA_VERSION:-12.4}"

